{
	"name": "pl_fintechData",
	"properties": {
		"activities": [
			{
				"name": "lkp_GetTableList",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT \n    TABLE_SCHEMA AS SchemaName,\n    TABLE_NAME AS TableName\nFROM \n    INFORMATION_SCHEMA.TABLES\nWHERE \n    TABLE_TYPE = 'BASE TABLE' and TABLE_SCHEMA = 'fintech'\nORDER BY \n    SchemaName, TableName;",
						"queryTimeout": "00:20:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_SQLSourceTables",
						"type": "DatasetReference"
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "fe_IterateOnEachTable",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "lkp_GetTableList",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('lkp_GetTableList').output.value",
						"type": "Expression"
					},
					"isSequential": false,
					"activities": [
						{
							"name": "cp_SQLDBToBronzeLayer",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "@concat('SELECT * FROM ',item().SchemaName,'.',item().TableName)",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"sink": {
									"type": "ParquetSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "ParquetWriteSettings"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_SQLSourceTables",
									"type": "DatasetReference"
								}
							],
							"outputs": [
								{
									"referenceName": "ds_BronzeLayerData",
									"type": "DatasetReference",
									"parameters": {
										"SchemaName": {
											"value": "@item().SchemaName",
											"type": "Expression"
										},
										"TableName": {
											"value": "@item().TableName",
											"type": "Expression"
										}
									}
								}
							]
						},
						{
							"name": "lkp_CountRecordsInSourceTable",
							"type": "Lookup",
							"dependsOn": [
								{
									"activity": "cp_SQLDBToBronzeLayer",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "AzureSqlSource",
									"sqlReaderQuery": {
										"value": "@concat('SELECT COUNT(*) AS src_count FROM ',item().SchemaName,'.',item().TableName)",
										"type": "Expression"
									},
									"queryTimeout": "02:00:00",
									"partitionOption": "None"
								},
								"dataset": {
									"referenceName": "ds_SQLSourceTables",
									"type": "DatasetReference"
								},
								"firstRowOnly": true
							}
						},
						{
							"name": "sc_CountRecordsFromBronzeLayerTable",
							"type": "Script",
							"dependsOn": [
								{
									"activity": "cp_SQLDBToBronzeLayer",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"linkedServiceName": {
								"referenceName": "ls_SynapseServerless",
								"type": "LinkedServiceReference"
							},
							"typeProperties": {
								"scripts": [
									{
										"type": "Query",
										"text": {
											"value": "SELECT COUNT(*) AS tgt_count\nFROM OPENROWSET(\n    BULK 'Bronze/@{item().SchemaName}/@{item().TableName}/*.parquet',\n    DATA_SOURCE = 'FintechDataExternal',\n    FORMAT = 'PARQUET'\n) AS rows;",
											"type": "Expression"
										}
									}
								],
								"scriptBlockExecutionTimeout": "02:00:00"
							}
						},
						{
							"name": "if_CheckCount",
							"type": "IfCondition",
							"dependsOn": [
								{
									"activity": "lkp_CountRecordsInSourceTable",
									"dependencyConditions": [
										"Succeeded"
									]
								},
								{
									"activity": "sc_CountRecordsFromBronzeLayerTable",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"userProperties": [],
							"typeProperties": {
								"expression": {
									"value": "@equals(\n    int(string(activity('lkp_CountRecordsInSourceTable').output.firstRow.src_count)),\n    int(string(activity('sc_CountRecordsFromBronzeLayerTable').output.resultSets[0].rows[0].tgt_count))\n     )",
									"type": "Expression"
								},
								"ifFalseActivities": [
									{
										"name": "FailPipeline",
										"type": "Fail",
										"dependsOn": [],
										"userProperties": [],
										"typeProperties": {
											"message": "source records count did not match with bronze records",
											"errorCode": "404"
										}
									}
								]
							}
						}
					]
				}
			},
			{
				"name": "nb_BronzeToSilverLayerProcessing",
				"type": "SynapseNotebook",
				"dependsOn": [
					{
						"activity": "fe_IterateOnEachTable",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebook": {
						"referenceName": "BronzeToSilverDataProcess",
						"type": "NotebookReference"
					},
					"snapshot": true,
					"sparkPool": {
						"referenceName": "sparkPool",
						"type": "BigDataPoolReference"
					},
					"executorSize": "Small",
					"driverSize": "Small"
				}
			},
			{
				"name": "nb_SilverToGoldLayerProcessing",
				"type": "SynapseNotebook",
				"dependsOn": [
					{
						"activity": "nb_BronzeToSilverLayerProcessing",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebook": {
						"referenceName": "SilverToGoldDataProcess",
						"type": "NotebookReference"
					},
					"snapshot": true,
					"sparkPool": {
						"referenceName": "sparkPool",
						"type": "BigDataPoolReference"
					},
					"executorSize": "Small",
					"driverSize": "Small"
				}
			},
			{
				"name": "web_SuccessEmail",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "nb_SilverToGoldLayerProcessing",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"headers": {
						"Content-Type": "application/json"
					},
					"url": "https://prod-23.polandcentral.logic.azure.com:443/workflows/d8935d8b83b84994acb16074b1816e41/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=ou01X7aUwozpznGg4EuNfD3HsajukSMmZ7n0lNfmf3I",
					"connectVia": {
						"referenceName": "AutoResolveIntegrationRuntime",
						"type": "IntegrationRuntimeReference"
					},
					"body": {
						"value": "{\n    \"to\":\"@{pipeline().parameters.to}\",\n    \"subject\":\"@{pipeline().parameters.subjectForSuccess}\",\n    \"emailmsg\":\"@{pipeline().parameters.emailMsgSuccess}\"\n}",
						"type": "Expression"
					}
				}
			},
			{
				"name": "web_FailedEmail",
				"type": "WebActivity",
				"dependsOn": [
					{
						"activity": "nb_SilverToGoldLayerProcessing",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"method": "POST",
					"headers": {
						"Content-Type": "application/json"
					},
					"url": "https://prod-23.polandcentral.logic.azure.com:443/workflows/d8935d8b83b84994acb16074b1816e41/triggers/When_an_HTTP_request_is_received/paths/invoke?api-version=2016-10-01&sp=%2Ftriggers%2FWhen_an_HTTP_request_is_received%2Frun&sv=1.0&sig=ou01X7aUwozpznGg4EuNfD3HsajukSMmZ7n0lNfmf3I",
					"connectVia": {
						"referenceName": "AutoResolveIntegrationRuntime",
						"type": "IntegrationRuntimeReference"
					},
					"body": {
						"value": "{\n    \"to\":\"@{pipeline().parameters.to}\",\n    \"subject\":\"@{pipeline().parameters.subjectForFailure}\",\n    \"emailmsg\":\"@{pipeline().parameters.emailMsgFailure}\"\n}",
						"type": "Expression"
					}
				}
			}
		],
		"parameters": {
			"to": {
				"type": "string",
				"defaultValue": "manishkumarrai3389@gmail.com"
			},
			"subjectForSuccess": {
				"type": "string",
				"defaultValue": "Fintech Data Pipeline Execution - SUCCESS"
			},
			"emailMsgSuccess": {
				"type": "string",
				"defaultValue": "Today's execution of fintech data pipeline is successfull."
			},
			"subjectForFailure": {
				"type": "string",
				"defaultValue": "Fintech Data Pipeline Execution - FAILED"
			},
			"emailMsgFailure": {
				"type": "string",
				"defaultValue": "Today's execution of fintech data pipeline is failed."
			}
		},
		"variables": {
			"TableName": {
				"type": "String"
			}
		},
		"annotations": []
	}
}